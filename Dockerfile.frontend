# ===================================
# A股自选股智能分析系统 - Frontend 镜像
# ===================================

FROM node:18-alpine

WORKDIR /app/frontend

# 复制依赖清单
COPY frontend/package.json frontend/package-lock.json* ./

# 安装依赖
RUN npm install

# 复制前端代码
COPY frontend ./

# 构建
RUN npm run build

EXPOSE 3000

CMD ["npm", "run", "start", "--", "-p", "3000"]
