{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Validator Placeholder Markers",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "markers"
  ],
  "properties": {
    "markers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
