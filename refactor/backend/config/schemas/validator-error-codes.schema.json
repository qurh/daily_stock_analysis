{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Validator Error Code Catalog",
  "type": "object",
  "required": [
    "summary_schema",
    "summary_contract",
    "placeholder_markers",
    "profile_suggestion_actions",
    "alertmanager_route_consistency",
    "notification_retry_runbook",
    "error_context_high_frequency"
  ],
  "additionalProperties": {
    "$ref": "#/$defs/group"
  },
  "$defs": {
    "group": {
      "type": "object",
      "minProperties": 1,
      "patternProperties": {
        "^[a-z][a-z0-9_]*$": {
          "$ref": "#/$defs/entry"
        }
      },
      "additionalProperties": false
    },
    "entry": {
      "type": "object",
      "required": [
        "description",
        "severity",
        "remediation"
      ],
      "properties": {
        "description": {
          "$ref": "#/$defs/non_empty_text"
        },
        "severity": {
          "type": "string",
          "enum": [
            "info",
            "warning",
            "error",
            "critical"
          ]
        },
        "remediation": {
          "$ref": "#/$defs/non_empty_text"
        }
      },
      "additionalProperties": false
    },
    "non_empty_text": {
      "type": "string",
      "minLength": 1
    }
  }
}
